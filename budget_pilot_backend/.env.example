# Supabase Postgres connection string.
# IMPORTANT: use the POOLER connection string, not "Direct connection".
# Direct connection (db.<ref>.supabase.co) is IPv6-only and will fail to resolve
# on most home/office Windows networks with "could not translate host name".
# Get the pooler string from: Project Settings -> Database -> Connection string
# -> "Transaction pooler" (or "Session pooler"). It looks like:
# postgresql://postgres.<project-ref>:[PASSWORD]@aws-0-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres

# Supabase Project Settings -> API
SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
SUPABASE_JWT_SECRET=your-jwt-secret-from-supabase-api-settings
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # needed only for /account deletion (deletes the auth user)

# Comma-separated list of origins allowed to call this API
CORS_ORIGINS=http://localhost:5173,https://your-frontend-domain.com
